DJANGO_SECRET_KEY=change-this-to-a-long-random-value
DJANGO_DEBUG=true
# Add the public hostname when accessing the app through DNS or a reverse proxy.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-server-hostname
# Add matching origins for browser form posts through the public hostname.
DJANGO_CSRF_TRUSTED_ORIGINS=http://your-server-hostname,https://your-server-hostname

CARTA_CURRENT_RULES_FILE=rules/carta-arcanum-2.1.4.rules.json
CARTA_INSTALLER_ENV_FILE=.env.local
CARTA_INSTALLER_LOCK_FILE=installer.lock

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=carta_arcanum
MYSQL_TEST_DATABASE=test_carta_arcanum
MYSQL_USER=carta
MYSQL_PASSWORD=change-me
